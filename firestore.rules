rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function signedInEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isSuperAdmin() {
      return signedInEmail() in [
        "digamber.yadav.dy@gmail.com"
      ];
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentUserStore() {
      return hasUserProfile() && currentUserData().storeId != null
        ? currentUserData().storeId
        : null;
    }

    function currentUserStatus() {
      return hasUserProfile() && currentUserData().status != null
        ? currentUserData().status
        : "inactive";
    }

    function isActiveStoreUser() {
      return hasUserProfile() && currentUserStatus() == "active";
    }

    function canAccessStore(storeId) {
      return isSuperAdmin()
        || (isSignedIn()
          && isActiveStoreUser()
          && storeId != null
          && currentUserStore() == storeId);
    }

    // Admin console metadata
    match /admin_stores/{storeId} {
      allow read: if isSuperAdmin() || canAccessStore(storeId);
      allow write: if isSuperAdmin();
    }

    // User profiles
    match /users/{uid} {
      allow read: if isSignedIn() && (isSuperAdmin() || uid == request.auth.uid);
      allow create, update, delete: if isSuperAdmin();
    }

    // Store-scoped top-level collections
    match /products/{docId} {
      allow read, delete: if canAccessStore(resource.data.storeId);
      allow create, update: if canAccessStore(request.resource.data.storeId);
    }

    match /orders/{docId} {
      allow read, delete: if canAccessStore(resource.data.storeId);
      allow create, update: if canAccessStore(request.resource.data.storeId);
    }

    match /customers/{docId} {
      allow read, delete: if canAccessStore(resource.data.storeId);
      allow create, update: if canAccessStore(request.resource.data.storeId);
    }

    match /expenses/{docId} {
      allow read, delete: if canAccessStore(resource.data.storeId);
      allow create, update: if canAccessStore(request.resource.data.storeId);
    }

    match /prescriptions/{docId} {
      allow read, delete: if canAccessStore(resource.data.storeId);
      allow create, update: if canAccessStore(request.resource.data.storeId);
    }

    match /public_invoices/{token} {
      allow get: if resource != null && resource.data.active == true;
      allow list: if false;
      allow create, update: if canAccessStore(request.resource.data.storeId);
      allow delete: if canAccessStore(resource.data.storeId);
    }

    match /public_invoice_orders/{orderId} {
      allow get: if resource != null && resource.data.active == true;
      allow list: if false;
      allow create, update: if canAccessStore(request.resource.data.storeId);
      allow delete: if canAccessStore(resource.data.storeId);
    }

    match /staff/{docId} {
      allow read, delete: if canAccessStore(resource.data.storeId);
      allow create, update: if canAccessStore(request.resource.data.storeId);
    }

    // Legacy sync/state documents still used by parts of the app.
    // These remain signed-in only for compatibility and should be
    // migrated to store-scoped docs in the next slice.
    match /app_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /orders_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /customers_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /expenses_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /staff_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /prescriptions_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /settings_state/{docId} {
      allow read, write: if isSignedIn();
    }

    // Tenant data: structure stores/{storeId}/...
    match /stores/{storeId}/{collection}/{docId} {
      allow read, write: if canAccessStore(storeId);
    }
  }
}
