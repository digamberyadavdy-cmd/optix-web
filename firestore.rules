rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userStore() {
      return request.auth != null && request.auth.token.storeId != null
        ? request.auth.token.storeId
        : null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.isAdmin == true;
    }

    // Admin console metadata
    match /admin_stores/{storeId} {
      allow read, write: if isAdmin();
    }

    // User profiles: admins can read/write, users can read their own
    match /users/{uid} {
      allow read: if isSignedIn() && (isAdmin() || uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Products collection (legacy, not under /stores)
    match /products/{docId} {
      allow read, write: if isSignedIn();
    }

    // Current app collections (top-level, storeId stored inside each doc)
    match /orders/{docId} {
      allow read, write: if isSignedIn();
    }

    match /customers/{docId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{docId} {
      allow read, write: if isSignedIn();
    }

    match /prescriptions/{docId} {
      allow read, write: if isSignedIn();
    }

    match /staff/{docId} {
      allow read, write: if isSignedIn();
    }

    // Legacy sync/state documents still used by parts of the app
    match /app_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /orders_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /customers_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /expenses_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /staff_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /prescriptions_state/{docId} {
      allow read, write: if isSignedIn();
    }

    match /settings_state/{docId} {
      allow read, write: if isSignedIn();
    }

    // Tenant data: structure stores/{storeId}/...
    match /stores/{storeId}/{collection}/{docId} {
      allow read, write: if isSignedIn() && (isAdmin() || userStore() == storeId);
    }
  }
}
